{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/service-worker.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      },
      "dest": "/manifest.json"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/anime-list/?",
      "dest": "/pages/catalog.html"
    },
    {
      "src": "/ongoing-anime/?",
      "dest": "/pages/ongoing-anime.html"
    },
    {
      "src": "/ongoing-anime/page/(.*)",
      "dest": "/pages/ongoing-anime.html"
    },
    {
      "src": "/complete-anime/?",
      "dest": "/pages/complete-anime.html"
    },
    {
      "src": "/complete-anime/page/(.*)",
      "dest": "/pages/complete-anime.html"
    },
    {
      "src": "/detail/(.*)",
      "dest": "/pages/detail.html"
    },
    {
      "src": "/anime/(.*)",
      "dest": "/pages/detail.html"
    },
    {
      "src": "/batch/(.*)",
      "dest": "/pages/batch.html"
    },
    {
      "src": "/episode/(.*)",
      "dest": "/pages/episode.html"
    },
    {
      "src": "/genre-list/?",
      "dest": "/pages/genre-list.html"
    },
    {
      "src": "/genres/(.*)/page/(.*)",
      "dest": "/pages/genre-list.html"
    },
    {
      "src": "/genres/(.*)",
      "dest": "/pages/genre-list.html"
    },
    {
      "src": "/schedule/?",
      "dest": "/pages/schedule.html"
    },
    {
      "src": "/search/?",
      "dest": "/pages/search.html"
    },
    {
      "src": "/status/?",
      "dest": "/pages/status.html"
    }
  ]
}
