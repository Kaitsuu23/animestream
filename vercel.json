{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/style/(.*)",
      "dest": "/public/style/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/icons/(.*)",
      "dest": "/public/icons/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/errors/(.*)",
      "dest": "/public/errors/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/public/pages/$1"
    },
    {
      "src": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/public/service-worker.js"
    },
    {
      "src": "/sw-register.js",
      "dest": "/public/sw-register.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      },
      "dest": "/public/manifest.json"
    },
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/",
      "dest": "server/server.js"
    },
    {
      "src": "/anime-list/?",
      "dest": "server/server.js"
    },
    {
      "src": "/ongoing-anime/?",
      "dest": "server/server.js"
    },
    {
      "src": "/ongoing-anime/page/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/complete-anime/?",
      "dest": "server/server.js"
    },
    {
      "src": "/complete-anime/page/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/detail/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/anime/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/batch/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/episode/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/genre-list/?",
      "dest": "server/server.js"
    },
    {
      "src": "/genres/(.*)/page/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/genres/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/schedule/?",
      "dest": "server/server.js"
    },
    {
      "src": "/search/?",
      "dest": "server/server.js"
    },
    {
      "src": "/status/?",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server/server.js"
    }
  ]
}
