{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(js|style|icons|errors|pages)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-cache",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/public/service-worker.js"
    },
    {
      "src": "/sw-register.js",
      "dest": "/public/sw-register.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      },
      "dest": "/public/manifest.json"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/anime-list/?",
      "dest": "/public/pages/catalog.html"
    },
    {
      "src": "/ongoing-anime/?",
      "dest": "/public/pages/ongoing-anime.html"
    },
    {
      "src": "/ongoing-anime/page/(.*)",
      "dest": "/public/pages/ongoing-anime.html"
    },
    {
      "src": "/complete-anime/?",
      "dest": "/public/pages/complete-anime.html"
    },
    {
      "src": "/complete-anime/page/(.*)",
      "dest": "/public/pages/complete-anime.html"
    },
    {
      "src": "/detail/(.*)",
      "dest": "/public/pages/detail.html"
    },
    {
      "src": "/anime/(.*)",
      "dest": "/public/pages/detail.html"
    },
    {
      "src": "/batch/(.*)",
      "dest": "/public/pages/batch.html"
    },
    {
      "src": "/episode/(.*)",
      "dest": "/public/pages/episode.html"
    },
    {
      "src": "/genre-list/?",
      "dest": "/public/pages/genre-list.html"
    },
    {
      "src": "/genres/(.*)/page/(.*)",
      "dest": "/public/pages/genre-list.html"
    },
    {
      "src": "/genres/(.*)",
      "dest": "/public/pages/genre-list.html"
    },
    {
      "src": "/schedule/?",
      "dest": "/public/pages/schedule.html"
    },
    {
      "src": "/search/?",
      "dest": "/public/pages/search.html"
    },
    {
      "src": "/status/?",
      "dest": "/public/pages/status.html"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/public/errors/404.html"
    }
  ],
  "error": {
    "404": "/public/errors/404.html",
    "500": "/public/errors/500.html"
  }
}
